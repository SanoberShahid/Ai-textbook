# Qdrant Configuration
# For local development, leave these as empty to use in-memory Qdrant
QDRANT_URL=
QDRANT_API_KEY=

# Embedding Configuration
# Use fast local embeddings for development (faster and no API key required)
USE_FAST_EMBEDDINGS=true

# Google API Configuration (only needed if not using fast embeddings)
# GOOGLE_API_KEY=your_google_api_key_here

# Collection name
COLLECTION_NAME=ai_textbook