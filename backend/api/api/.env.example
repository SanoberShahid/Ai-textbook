cdcdcd# Google API Configuration
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Qdrant Configuration
QDRANT_URL=YOUR_QDRANT_URL_HERE
QDRANT_API_KEY=YOUR_QDRANT_API_KEY_HERE
QDRANT_COLLECTION_NAME=ai_textbook

# Fast Embeddings Configuration
# Set to true to use fast local embeddings, false to use Google API
USE_FAST_EMBEDDINGS=true

# Name of the sentence-transformer model to use
# Options: all-MiniLM-L6-v2 (default), all-MiniLM-L12-v2, paraphrase-multilingual-MiniLM-L12-v2, etc.
FAST_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Device to run embeddings on (cpu, cuda, mps, or auto-detect)
EMBEDDING_DEVICE=auto

# Performance settings
EMBEDDING_BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=true

# Qdrant distance metric (Cosine, Euclidean, Dot)
QDRANT_DISTANCE_METRIC=Cosine

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001